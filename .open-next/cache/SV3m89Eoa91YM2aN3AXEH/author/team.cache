mn.js\" async=\"\"></script><link rel=\"preload\" href=\"https://www.googletagmanager.com/gtag/js?id=G-95PY8PSZ0Y\" as=\"script\"/><meta name=\"msvalidate.01\" content=\"C396E9907374E29FB46754412E4E3FB7\"/><title>Our Team - AutoMotoFlux - Vehicle Parts &amp; Accessories Guide</title><meta name=\"description\" content=\"Meet the expert team behind AutoMotoFlux - Vehicle Parts &amp; Accessories Guide.\"/><link rel=\"canonical\" href=\"https://automotoflux.com\"/><meta property=\"og:title\" content=\"AutoMotoFlux - Vehicle Parts &amp; Accessories Guide\"/><meta property=\"og:description\" content=\"Expert guides on vehicle parts, auto accessories, and automotive maintenance. From engine components to exterior upgrades, find trusted advice for every driver.\"/><meta property=\"og:url\" content=\"https://automotoflux.com\"/><meta property=\"og:image\" content=\"https://s.alicdn.com/@sc02/kf/A08fc6fd610aa41f5bd7e913d02989e51F.jpg\"/><meta property=\"og:image:width\" content=\"1200\"/><meta property=\"og:image:height\" content=\"630\"/><meta property=\"og:image:alt\" content=\"AutoMotoFlux - Vehicle Parts &amp; Accessories Guide\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"AutoMotoFlux - Vehicle Parts &amp; Accessories Guide\"/><meta name=\"twitter:description\" content=\"Expert guides on vehicle parts, auto accessories, and automotive maintenance. From engine components to exterior upgrades, find trusted advice for every driver.\"/><meta name=\"twitter:image\" content=\"https://s.alicdn.com/@sc02/kf/A08fc6fd610aa41f5bd7e913d02989e51F.jpg\"/><script type=\"application/ld+json\">{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"AutoMotoFlux - Vehicle Parts & Accessories Guide\",\"url\":\"https://automotoflux.com\",\"description\":\"Expert guides on vehicle parts, auto accessories, and automotive maintenance. From engine components to exterior upgrades, find trusted advice for every driver.\"}</script><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><header class=\"site-header\"><a class=\"logo\" href=\"/\">AutoMotoFlux</a><nav class=\"main-nav\"><a href=\"/engine-parts\">Engine Parts</a><a href=\"/exterior-accessories\">Exterior Accessories</a><a href=\"/interior-upgrades\">Interior Upgrades</a><a href=\"/wheels-tires\">Wheels &amp; Tires</a><a href=\"/electrical-systems\">Electrical Systems</a><a href=\"/maintenance-tools\">Maintenance &amp; Tools</a><a href=\"/author/team\">Authors</a></nav></header><main><div class=\"authors-page\"><section class=\"authors-banner\"><h1>Our Expert Team</h1><p>Meet the professionals behind our content.</p></section><section class=\"authors-grid\"><a class=\"author-card\" href=\"/author/marcus-chen\"><div class=\"author-avatar\"><img src=\"https://s.alicdn.com/@sc02/kf/A7a96e9403a13490e9cd7cf095d7d9099P.jpg\" alt=\"Marcus Chen\" width=\"80\" height=\"80\"/></div><h3>Marcus Chen</h3><p>ASE-certified master technician with 15 years of experience in engine diagnostics and performance tuning. Marcus specializes in powertrain systems and turbocharger upgrades.</p></a><a class=\"author-card\" href=\"/author/sarah-mitchell\"><div class=\"author-avatar\"><img src=\"https://s.alicdn.com/@sc02/kf/Af621ad47559a422b9d91e9ccec8ccee4n.jpg\" alt=\"Sarah Mitchell\" width=\"80\" height=\"80\"/></div><h3>Sarah Mitchell</h3><p>Automotive journalist and former pit crew member who covers exterior styling, aerodynamics, and paint protection technology. Sarah has reviewed over 200 aftermarket body kits.</p></a><a class=\"author-card\" href=\"/author/david-kowalski\"><div class=\"author-avatar\"><img src=\"https://s.alicdn.com/@sc02/kf/A80732c88fc43486189e9f92ea64e0512c.jpg\" alt=\"David Kowalski\" width=\"80\" height=\"80\"/></div><h3>David Kowalski</h3><p>Electrical engineer turned automotive writer focusing on vehicle electronics, EV conversions, and modern infotainment systems. David holds multiple patents in automotive sensor design.</p></a><a class=\"author-card\" href=\"/author/rachel-torres\"><div class=\"author-avatar\"><img src=\"https://s.alicdn.com/@sc02/kf/Aa00f2047261549b3a01b1a5f0fee921b6.jpg\" alt=\"Rachel Torres\" width=\"80\" height=\"80\"/></div><h3>Rachel Torres</h3><p>Tire industry consultant and former Michelin test driver with deep expertise in tire compound science, wheel fitment, and alignment optimization for street and track use.</p></a><a class=\"author-card\" href=\"/author/james-henderson\"><div class=\"author-avatar\"><img src=\"https://s.alicdn.com/@sc02/kf/A266efbb93dbb4522a8c10f49a74882fa0.jpg\" alt=\"James Henderson\" width=\"80\" height=\"80\"/></div><h3>James Henderson</h3><p>Interior design specialist with 12 years at a major OEM before transitioning to aftermarket consulting. James covers seat upgrades, sound deadening, and cabin electronics.</p></a><a class=\"author-card\" href=\"/author/lisa-park\"><div class=\"author-avatar\"><img src=\"https://s.alicdn.com/@sc02/kf/A9721d8cdadcb4cd588dbe5e9f49c9b57o.jpg\" alt=\"Lisa Park\" width=\"80\" height=\"80\"/></div><h3>Lisa Park</h3><p>DIY maintenance advocate and tool reviewer who has built three project cars from the ground up. Lisa makes complex repairs accessible to home mechanics of all skill levels.</p></a><a class=\"author-card\" href=\"/author/robert-fernandez\"><div class=\"author-avatar\"><img src=\"https://s.alicdn.com/@sc02/kf/A3079f116c3fe4a6b89fb642cd593e6cc3.jpg\" alt=\"Robert Fernandez\" width=\"80\" height=\"80\"/></div><h3>Robert Fernandez</h3><p>Former NASCAR crew chief who now writes about high-performance parts, suspension tuning, and brake system upgrades. Robert brings professional motorsport insight to street applications.</p></a><a class=\"author-card\" href=\"/author/nina-volkov\"><div class=\"author-avatar\"><img src=\"https://s.alicdn.com/@sc02/kf/Aebb8d0a650d9406ca6d76481ece5a977S.jpg\" alt=\"Nina Volkov\" width=\"80\" height=\"80\"/></div><h3>Nina Volkov</h3><p>Materials scientist specializing in automotive coatings, corrosion prevention, and advanced composites. Nina bridges the gap between laboratory research and practical aftermarket solutions.</p></a></section></div><!--$--><!--/$--></main><footer class=\"site-footer\"><div class=\"footer-content\"><div class=\"footer-brand\"><span class=\"footer-logo\">AutoMotoFlux - Vehicle Parts &amp; Accessories Guide</span><p>Expert guides on vehicle parts, auto accessories, and automotive maintenance. From engine components to exterior upgrades, find trusted advice for every driver.</p></div><nav class=\"footer-nav\"><h4>Categories</h4><ul><li><a href=\"/engine-parts\">Engine Parts</a></li><li><a href=\"/exterior-accessories\">Exterior Accessories</a></li><li><a href=\"/interior-upgrades\">Interior Upgrades</a></li><li><a href=\"/wheels-tires\">Wheels &amp; Tires</a></li><li><a href=\"/electrical-systems\">Electrical Systems</a></li><li><a href=\"/maintenance-tools\">Maintenance &amp; Tools</a></li></ul></nav><nav class=\"footer-nav\"><h4>Site</h4><ul><li><a href=\"/\">Home</a></li><li><a href=\"/author/team\">Authors</a></li></ul></nav></div><div class=\"footer-bottom\"><p>© <!-- -->2026<!-- --> <!-- -->AutoMotoFlux - Vehicle Parts &amp; Accessories Guide<!-- -->. All rights reserved.</p></div></footer><script src=\"/_next/static/chunks/09_s5dke11abe.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[79520,[\\\"/_next/static/chunks/0t0~vf8vpn6e-.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"\\\"]\\n3:I[22016,[\\\"/_next/static/chunks/0t0~vf8vpn6e-.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"\\\"]\\n4:I[39756,[\\\"/_next/static/chunks/0t0~vf8vpn6e-.js\\\",\\\"/_next/static/chunks/0d3shmwh5_nmn.js\\\"],\\\"default\\\"]\\n5:I[37457,[\\\"/_next/static/chunk